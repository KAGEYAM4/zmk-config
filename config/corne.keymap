#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    macros {
        bt_sel_cl: bt_sel_cl {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&macro_param_1to2 &bt BT_SEL MACRO_PLACEHOLDER &bt BT_CLR>;
            label = "BT_SEL_CL";
        };
    };

    behaviors {
	hml: home_row_mod_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <150>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;
	    //hold-trigger-key-positions = < ... >; // List of keys on the right side of the keyboard
            //hold-trigger-on-release;
        };

        hmr: home_row_mod_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <150>;
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;
            //hold-trigger-key-positions = < ... >; // List of keys on the left side of the keyboard
            //hold-trigger-on-release;
        };

        my_bt_0: my_bt_0 {
            compatible = "zmk,behavior-mod-morph";
            label = "MY_BT_0";
            bindings = <&bt BT_SEL 0>, <&bt_sel_cl 0>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        my_bt_1: my_bt_1 {
            compatible = "zmk,behavior-mod-morph";
            label = "MY_BT_1";
            bindings = <&bt BT_SEL 1>, <&bt_sel_cl 1>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        my_bt_2: my_bt_2 {
            compatible = "zmk,behavior-mod-morph";
            label = "MY_BT_2";
            bindings = <&bt BT_SEL 2>, <&bt_sel_cl 2>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        my_bt_3: my_bt_3 {
            compatible = "zmk,behavior-mod-morph";
            label = "MY_BT_3";
            bindings = <&bt BT_SEL 3>, <&bt_sel_cl 3>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        my_bt_4: my_bt_4 {
            compatible = "zmk,behavior-mod-morph";
            label = "MY_BT_4";
            bindings = <&bt BT_SEL 4>, <&bt_sel_cl 4>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        my_vol_br_i: my_vol_br_i {
            compatible = "zmk,behavior-mod-morph";
            label = "MY_VOL_BR_I";
            bindings = <&kp C_VOLUME_UP>, <&kp C_BRIGHTNESS_INC>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        my_vol_br_d: my_vol_br_d {
            compatible = "zmk,behavior-mod-morph";
            label = "MY_VOL_BR_D";
            bindings = <&kp C_VOLUME_DOWN>, <&kp C_BRIGHTNESS_DEC>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        my_bootloader: my_bootloader {
            compatible = "zmk,behavior-tap-dance";
            label = "MY_BOOTLOADER";
            #binding-cells = <0>;
            bindings = <&none>, <&bootloader>;

            tapping-term-ms = <200>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base_layer {
            bindings = <
&none  &kp Q           &kp W            &kp F               &kp P             &kp B        &kp J        &kp L             &kp U               &kp Y                 &kp SQT         &none
&none  &hml LEFT_GUI A  &hml LEFT_ALT R   &hml LEFT_CONTROL S  &hml LEFT_SHIFT T  &kp G        &kp M        &hmr LEFT_SHIFT N  &hmr LEFT_CONTROL E  &hmr LEFT_ALT I        &hmr LEFT_GUI O  &none
&none  &kp Z           &hml RIGHT_ALT X  &kp C               &kp D             &kp V        &kp K        &kp H             &kp COMMA           &hmr RIGHT_ALT PERIOD  &kp FSLH        &none
                                        &lt 4 ESCAPE        &lt 1 SPACE       &lt 3 TAB    &lt 6 ENTER  &lt 5 BACKSPACE   &lt 7 DELETE
            >;
        };

        nav_layer {
            bindings = <
&none  &none           &none          &none      &none      &none    &kp K_REDO    &kp K_PASTE  &kp K_COPY  &kp K_CUT  &kp K_UNDO  &none
&none  &kp LGUI        &kp LEFT_ALT   &kp LCTRL  &kp LSHFT  &none    &kp CAPSLOCK  &kp LEFT     &kp DOWN    &kp UP     &kp RIGHT   &none
&none  &my_bootloader  &kp RIGHT_ALT  &to 5      &to 1      &to 0    &kp INS       &kp HOME     &kp PG_DN   &kp PG_UP  &kp END     &none
                                      &none      &none      &none    &kp RET       &kp BSPC     &kp DEL
            >;
        };

        button_layer {
            bindings = <
&none  &kp K_UNDO    &kp K_CUT  &kp K_COPY  &kp K_PASTE  &kp K_REDO    &kp K_REDO  &kp K_PASTE  &kp K_COPY  &kp K_CUT  &kp K_UNDO  &none
&none  &kp LEFT_GUI  &kp LALT   &kp LCTRL   &kp LSHFT    &none         &none       &kp LSHFT    &kp LCTRL   &kp LALT   &kp LGUI    &none
&none  &kp K_UNDO    &kp K_CUT  &kp K_COPY  &kp K_PASTE  &kp K_REDO    &kp K_REDO  &kp K_PASTE  &kp K_COPY  &kp K_CUT  &kp K_UNDO  &none
                                &mkp MCLK   &mkp LCLK    &mkp RCLK     &mkp RCLK   &mkp LCLK    &mkp MCLK
            >;
        };

        mouse_layer {
            bindings = <
&none  &none           &none          &none      &none      &none    &kp K_REDO  &kp K_PASTE     &kp K_COPY      &kp K_CUT     &kp K_UNDO       &none
&none  &kp LGUI        &kp LALT       &kp LCTRL  &kp LSHFT  &none    &none       &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_UP  &mmv MOVE_RIGHT  &none
&none  &my_bootloader  &kp RIGHT_ALT  &to 6      &to 3      &to 0    &none       &msc SCRL_LEFT  &msc SCRL_DOWN  &msc SCRL_UP  &msc SCRL_RIGHT  &none
                                      &none      &none      &none    &mkp RCLK   &mkp LCLK       &mkp MCLK
            >;
        };

        media_layer {
            bindings = <
&none  &none           &none          &none      &none      &none    &none              &none             &none         &none         &none       &none
&none  &kp LGUI        &kp LALT       &kp LCTRL  &kp LSHFT  &none    &ext_power EP_TOG  &kp C_PREV        &my_vol_br_d  &my_vol_br_i  &kp C_NEXT  &none
&none  &my_bootloader  &kp RIGHT_ALT  &to 7      &to 4      &to 0    &out OUT_TOG       &my_bt_0          &my_bt_1      &my_bt_2      &my_bt_3    &none
                                      &none      &none      &none    &kp C_STOP         &kp C_PLAY_PAUSE  &kp C_MUTE
            >;
        };

        num_layer {
            bindings = <
&none  &kp LBKT   &kp N7  &kp N8   &kp N9  &kp RBKT     &none  &none      &none      &none          &none           &none
&none  &kp SEMI   &kp N4  &kp N5   &kp N6  &kp EQUAL    &none  &kp LSHFT  &kp LCTRL  &kp LALT       &kp LGUI        &none
&none  &kp GRAVE  &kp N1  &kp N2   &kp N3  &kp BSLH     &to 0  &to 5      &to 1      &kp RIGHT_ALT  &my_bootloader  &none
                          &kp DOT  &kp N0  &kp MINUS    &none  &none      &none
            >;
        };

        sym_layer {
            bindings = <
&none  &kp LEFT_BRACE  &kp AMPERSAND  &kp ASTERISK          &kp LEFT_PARENTHESIS   &kp RIGHT_PARENTHESIS    &none  &none      &none      &none          &none           &none
&none  &kp COLON       &kp DOLLAR     &kp PERCENT           &kp CARET              &kp PLUS                 &none  &kp LSHFT  &kp LCTRL  &kp LALT       &kp LGUI        &none
&none  &kp MINUS       &kp EXCL       &kp AT_SIGN           &kp POUND              &kp PIPE                 &to 0  &to 6      &to 3      &kp RIGHT_ALT  &my_bootloader  &none
                                      &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp UNDERSCORE           &none  &none      &none
            >;
        };

        fun_layer {
            bindings = <
&none  &kp F12  &kp F7  &kp F8              &kp F9     &kp PRINTSCREEN    &none  &none      &none      &none          &none           &none
&none  &kp F11  &kp F4  &kp F5              &kp F6     &kp SCROLLLOCK     &none  &kp LSHFT  &kp LCTRL  &kp LALT       &kp LGUI        &none
&none  &kp F10  &kp F1  &kp F2              &kp F3     &kp PAUSE_BREAK    &to 0  &to 7      &tog 4     &kp RIGHT_ALT  &my_bootloader  &none
                        &kp K_CONTEXT_MENU  &kp SPACE  &kp TAB            &none  &none      &none
            >;
        };
    };
};

